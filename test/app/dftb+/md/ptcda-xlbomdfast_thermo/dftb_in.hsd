Geometry = GenFormat {
    <<< "geom.gen"
}

Driver = VelocityVerlet{
    XlbomdFast {
        PreSteps = 0
        TransientSteps = 10
        IntegrationSteps = 5
        Scale = 0.5 
    }
    TimeStep [fs] = 0.1
    Thermostat = Langevin {
        Temperature [Kelvin] = 298
        Frequency [cm^-1] = 3000 # Approximte C-H stretch region
    }
    Steps = 100
    MovedAtoms = 1:-1
}

Hamiltonian = DFTB {
    SCC = Yes
    SCCTolerance = 1e-6
    Filling = Fermi {
        Temperature [Kelvin] = 298
    }
    SlaterKosterFiles = Type2FileNames {
        Prefix = "slakos/origin/mio-1-1/"
        Separator = "-"
        Suffix = ".skf" 
    }
    MaxAngularMomentum {
        H = "s"
        O = "p"
        C = "p"
    }
    ForceEvaluation = Dynamics
    ThirdOrderFull = Yes
    HCorrection = Damping {
        Exponent = 4.0
    }
    HubbardDerivs {
        C = -0.1492
        H = -0.1857
        O = -0.1575
    }
}

Options {
    RandomSeed = 3871906
    WriteAutotestTag = Yes
}

ParserOptions {
    ParserVersion = 14
}

Parallel {
    # Allow OMP threads explicitely to test for hybrid parallelisation with
    # MPI-binary. (Check the manual before using this in production runs!)
    UseOmpThreads = Yes
}
